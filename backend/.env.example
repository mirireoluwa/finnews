# After cloning or pulling: pip install -r requirements.txt (installs dj-database-url, whitenoise, gunicorn, etc.)
# Copy to `.env` in this folder and fill in values. Restart `python manage.py runserver` after changes.

# Required for real headlines (free tier: https://newsapi.org/register )
# One line, no spaces around =, usually no quotes:
# NEWSAPI_API_KEY=your_newsapi_key_here
NEWSAPI_API_KEY=

# Optional: more articles per region (default 24 fetched, up to 30 kept). NewsAPI max pageSize is 100.
# Lower pageSize = same 1 request but slightly smaller payload (does not change daily request quota).
# NEWSAPI_MARKET_PAGE_SIZE=24
# MAX_MARKET_STORIES=30

# Optional: company search in the watchlist UI (Alpha Vantage)
ALPHAVANTAGE_API_KEY=

# Production: comma-separated origins allowed to call the API (e.g. your Vercel app).
# Defaults to local Vite dev server if unset.
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Optional (Render + Vercel): allow any https://*.vercel.app for preview deployments
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Optional production
# DJANGO_SECRET_KEY=
# ALLOWED_HOSTS=your-api.onrender.com
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
