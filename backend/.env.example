# After cloning or pulling: pip install -r requirements.txt (installs dj-database-url, whitenoise, gunicorn, etc.)
# Copy to `.env` in this folder and fill in values. Restart `python manage.py runserver` after changes.

# Required for real headlines (free tier: https://newsapi.org/register )
# One line, no spaces around =, usually no quotes:
# NEWSAPI_API_KEY=your_newsapi_key_here
NEWSAPI_API_KEY=

# Optional: more articles per region (default 24 fetched, up to 30 kept). NewsAPI max pageSize is 100.
# Lower pageSize = same 1 request but slightly smaller payload (does not change daily request quota).
# NEWSAPI_MARKET_PAGE_SIZE=24
# MAX_MARKET_STORIES=30

# Optional: watchlist / onboarding company search (symbol lookup)
# Exact name must match. Alternatives also accepted: ALPHA_VANTAGE_API_KEY, ALPHAVANTAGE_KEY
# No quotes around the value. Free tier is heavily rate-limited (see README).
ALPHAVANTAGE_API_KEY=

# Production: comma-separated origins allowed to call the API (e.g. https://fin-news.xyz).
# Defaults to local Vite dev server if unset.
# CORS_ALLOWED_ORIGINS=https://fin-news.xyz,http://localhost:5173

# Optional (Render + Vercel): allow any https://*.vercel.app for preview deployments
# CORS_ALLOW_VERCEL_PREVIEWS=true

# Password reset emails: public URL of the React app (no trailing slash). Required for reset links in production.
# FRONTEND_URL=https://fin-news.xyz
# Local dev: http://localhost:5173

# --- SMTP for password-reset emails (set on Render for production) ---
# If EMAIL_HOST is unset, reset emails only appear in server logs (console backend).
#
# Gmail (use an App Password, not your normal login password):
# 1) Google Account → Security → turn on 2-Step Verification
# 2) Security → App passwords → create "Mail" / "Other" → copy the 16-character password
# 3) On Render, add these Environment variables (no quotes around values):
#
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=youraddress@gmail.com
# EMAIL_HOST_PASSWORD=abcdabcdabcdabcd
# DEFAULT_FROM_EMAIL=FinNews <youraddress@gmail.com>
#
# Other providers: set EMAIL_HOST / EMAIL_HOST_USER / EMAIL_HOST_PASSWORD per their SMTP docs.

# Optional production
# DJANGO_SECRET_KEY=
# ALLOWED_HOSTS=your-api.onrender.com
# CSRF_TRUSTED_ORIGINS=https://fin-news.xyz
