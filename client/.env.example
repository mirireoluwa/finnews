# Production: set in your host dashboard (e.g. Vercel) and redeploy. API on Render, etc.
# No trailing slash.
# VITE_API_URL=https://finnews-api.onrender.com

# Public site origin for Open Graph / social link previews (og:image, og:url). No trailing slash.
# On Vercel this is optional: VERCEL_URL is used automatically if unset.
# Set explicitly when using a custom domain (e.g. https://fin-news.xyz) so previews match the URL you share.
# VITE_SITE_URL=https://fin-news.xyz
