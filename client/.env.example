# Production: set in your host dashboard (e.g. Vercel) and redeploy. API on Render, etc.
# No trailing slash.
# VITE_API_URL=https://finnews-api.onrender.com

# Public site origin for Open Graph / social link previews (og:image must be absolute https for many apps).
# No trailing slash. Strongly recommended on Vercel when using a custom domain (e.g. https://fin-news.xyz).
# Build order: VITE_SITE_URL → VERCEL_PROJECT_PRODUCTION_URL → VERCEL_URL.
# VITE_SITE_URL=https://fin-news.xyz
